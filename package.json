{
    "name": "mellow-scss",
    "version": "4.0.0",
    "description": "",
    "main": "src/main.scss",
    "scripts": {
        "build": "sass --no-source-map src/main.scss dist/mellow.css",
        "build:watch": "sass --watch src:dist/css",
        "prettier": "prettier --check \"src/**/*.scss\"",
        "prettier:fix": "prettier --write \"src/**/*.scss\"",
        "stylelint": "stylelint \"src/**/*.scss\"",
        "stylelint:fix": "stylelint --fix \"src/**/*.scss\"",
        "lint:fix": "npm run prettier:fix && npm run stylelint:fix",
        "test:lint": "npm run prettier && npm run stylelint",
        "test:sass": "jest test/sass.test.js",
        "test": "npm run test:lint && npm run test:sass",
        "prepare": "husky",
        "semantic-release": "semantic-release"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Mellow254/Mellow-CSS.git"
    },
    "keywords": [],
    "author": "James Macharia",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/Mellow254/Mellow-CSS/issues"
    },
    "homepage": "https://github.com/Mellow254/Mellow-CSS#readme",
    "devDependencies": {
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "sass": "^1.98.0",
        "sass-true": "^10.1.0",
        "semantic-release": "^25.0.3",
        "stylelint": "^17.6.0",
        "stylelint-config-standard-scss": "^17.0.0"
    }
}
